DATABASE_URL=postgresql+asyncpg://fundus:fundus@localhost:5432/fundus_recommend
DATABASE_URL_SYNC=postgresql+psycopg2://fundus:fundus@localhost:5432/fundus_recommend
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
DEDUP_THRESHOLD=0.70
TOP_STORY_MIN_SOURCES=3
TOP_STORY_SCORE_POPULARITY_WEIGHT=0.45
TOP_STORY_SCORE_COVERAGE_WEIGHT=0.35
TOP_STORY_SCORE_REPUTATION_WEIGHT=0.20
CRAWL_TIMEOUT_SECONDS=20
CRAWL_MAX_RETRIES=2
CRAWL_BACKOFF_SECONDS=1.0
CRAWL_RATE_LIMIT_PER_MINUTE=30
CRAWL_CIRCUIT_BREAKER_THRESHOLD=5
CRAWL_CIRCUIT_BREAKER_COOLDOWN_SECONDS=900

# Article body storage mode: database | dual | r2_primary
ARTICLE_BODY_STORAGE_MODE=database
ARTICLE_BODY_SNIPPET_CHARS=1000

# Cloudflare R2 credentials/config
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional: defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ENDPOINT=
R2_REGION=auto
R2_TIMEOUT_SECONDS=10

# CORS origins (comma-separated for multiple, used by API server)
CORS_ORIGINS=http://localhost:3000

# Frontend API URL (set at build time for Next.js)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Scheduler runtime defaults (used by scripts/start-scheduler-once.sh)
SCHEDULER_PUBLISHERS=all-countries
SCHEDULER_MAX_ARTICLES=25
SCHEDULER_WORKERS=8
SCHEDULER_BATCH_SIZE=64
SCHEDULER_INTERVAL_MINUTES=5
SCHEDULER_STALE_REFRESH_LIMIT=1000
SCHEDULER_RUN_MODE=loop
# SCHEDULER_LANGUAGE=en
